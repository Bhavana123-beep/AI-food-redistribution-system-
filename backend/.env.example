# Copy this file to .env and fill in your values

# MongoDB connection string
# Option 1 — Local MongoDB (default, no setup needed if MongoDB is installed):
MONGO_URI=mongodb://127.0.0.1:27017/foodrescue

# Option 2 — MongoDB Atlas (cloud, free tier):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/foodrescue?retryWrites=true&w=majority

# JWT Secret — change this in production!
JWT_SECRET=foodrescue_secret_key_2026

# Server port
PORT=5000
